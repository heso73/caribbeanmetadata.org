{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caribbeanmetadata.org/schema/v1.0/cms-metadata.json",
  "title": "Caribbean Metadata Standard",
  "description": "Schéma officiel de métadonnées culturelles caribéennes — CMS v1.0",
  "version": "1.0.0",
  "issued": "2026-04-11",
  "publisher": "Caribwood Language Lab",
  "type": "object",

  "required": [
    "cms_version",
    "content_type",
    "identity",
    "origin",
    "language",
    "cultural_markers"
  ],

  "properties": {

    "cms_version": {
      "type": "string",
      "const": "1.0",
      "description": "Version du standard CMS utilisée"
    },

    "content_type": {
      "type": "string",
      "description": "Type principal du contenu culturel",
      "enum": [
        "audiovisual",
        "musical",
        "literary",
        "heritage"
      ],
      "cms:labels": {
        "audiovisual": { "fr": "Audiovisuel", "en": "Audiovisual", "es": "Audiovisual", "ht": "Odyo-Vizèl" },
        "musical":     { "fr": "Musical",     "en": "Musical",     "es": "Musical",     "ht": "Mizik" },
        "literary":    { "fr": "Littéraire",  "en": "Literary",    "es": "Literario",   "ht": "Literè" },
        "heritage":    { "fr": "Patrimonial", "en": "Heritage",    "es": "Patrimonial", "ht": "Patrimwàn" }
      }
    },

    "content_subtype": {
      "type": "string",
      "description": "Sous-type précis selon le content_type",
      "cms:subtypes": {
        "audiovisual": ["film", "series", "documentary", "short_film", "music_video", "web_series"],
        "musical":     ["album", "single", "ep", "live_recording", "traditional_recording"],
        "literary":    ["novel", "poetry", "short_story", "essay", "oral_text", "script"],
        "heritage":    ["oral_tradition", "craft", "ceremony", "gastronomy", "dance", "archive"]
      }
    },

    "identity": {
      "type": "object",
      "description": "Identification principale du contenu",
      "required": ["title", "creator"],
      "properties": {

        "title": {
          "type": "object",
          "description": "Titre du contenu dans les langues disponibles",
          "properties": {
            "original":  { "type": "string" },
            "fr":        { "type": "string" },
            "en":        { "type": "string" },
            "es":        { "type": "string" },
            "ht":        { "type": "string", "description": "Créole haïtien" },
            "gcf":       { "type": "string", "description": "Créole guadeloupéen/martiniquais" },
            "pap":       { "type": "string", "description": "Papiamentu (Aruba, Curaçao)" }
          },
          "required": ["original"]
        },

        "creator": {
          "type": "array",
          "description": "Créateur(s) principal(aux) du contenu",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "role"],
            "properties": {
              "name":        { "type": "string" },
              "role":        { "type": "string", "enum": ["director", "author", "composer", "performer", "artist", "archivist", "narrator", "producer"] },
              "nationality": { "type": "string" },
              "diaspora":    { "type": "boolean", "description": "Créateur de la diaspora caribéenne" }
            }
          }
        },

        "year_of_creation": {
          "type": "integer",
          "minimum": 1400,
          "maximum": 2100
        },

        "year_of_release": {
          "type": "integer",
          "minimum": 1400,
          "maximum": 2100
        },

        "duration_seconds": {
          "type": "integer",
          "description": "Durée totale en secondes (audiovisuel et musical)"
        },

        "isbn_issn_isan": {
          "type": "string",
          "description": "Identifiant standardisé externe (ISBN, ISSN, ISAN, ISRC)"
        }
      }
    },

    "origin": {
      "type": "object",
      "description": "Origine géographique et culturelle du contenu",
      "required": ["territory"],
      "properties": {

        "territory": {
          "type": "array",
          "description": "Territoire(s) d'origine",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "GP", "MQ", "GF", "BL", "MF",
              "HT", "DO", "CU", "PR", "JM",
              "TT", "BB", "LC", "VC", "GD",
              "AG", "DM", "KN", "BS", "TC",
              "AW", "CW", "SX", "BQ", "VG",
              "VI", "KY", "MS", "AI", "BM",
              "SR", "GY", "DIASPORA"
            ],
            "cms:territory_names": {
              "GP": "Guadeloupe", "MQ": "Martinique", "GF": "Guyane française",
              "BL": "Saint-Barthélemy", "MF": "Saint-Martin",
              "HT": "Haïti", "DO": "République Dominicaine", "CU": "Cuba",
              "PR": "Porto Rico", "JM": "Jamaïque",
              "TT": "Trinité-et-Tobago", "BB": "Barbade", "LC": "Sainte-Lucie",
              "VC": "Saint-Vincent", "GD": "Grenade",
              "AG": "Antigua-et-Barbuda", "DM": "Dominique", "KN": "Saint-Kitts",
              "AW": "Aruba", "CW": "Curaçao", "SX": "Sint Maarten",
              "SR": "Suriname", "GY": "Guyana", "DIASPORA": "Diaspora caribéenne"
            }
          }
        },

        "production_country": {
          "type": "array",
          "description": "Pays de production (peut différer du territoire d'origine)",
          "items": { "type": "string", "pattern": "^[A-Z]{2}$" }
        },

        "location_shoot": {
          "type": "array",
          "description": "Lieux de tournage / enregistrement",
          "items": {
            "type": "object",
            "properties": {
              "name":      { "type": "string" },
              "territory": { "type": "string" },
              "lat":       { "type": "number" },
              "lon":       { "type": "number" }
            }
          }
        }
      }
    },

    "language": {
      "type": "object",
      "description": "Langues présentes dans le contenu",
      "required": ["primary"],
      "properties": {

        "primary": {
          "type": "string",
          "description": "Langue principale du contenu",
          "enum": ["fr", "en", "es", "ht", "gcf", "pap", "srn", "other"]
        },

        "additional": {
          "type": "array",
          "description": "Langues secondaires présentes",
          "items": { "type": "string" }
        },

        "subtitles": {
          "type": "array",
          "description": "Langues de sous-titrage disponibles",
          "items": { "type": "string" }
        },

        "creole_variant": {
          "type": "string",
          "description": "Variante créole spécifique si applicable",
          "enum": ["guadeloupean", "martiniquais", "haitian", "saint_lucian", "trinidadian", "papiamentu", "sranan", "other"]
        }
      }
    },

    "cultural_markers": {
      "type": "object",
      "description": "Marqueurs culturels caribéens — cœur du standard CMS",
      "required": ["caribbean_identity_score", "themes"],
      "properties": {

        "caribbean_identity_score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100,
          "description": "Score d'ancrage caribéen (0 = aucun ancrage, 100 = ancrage total). Calculé selon les critères CMS."
        },

        "themes": {
          "type": "array",
          "description": "Thématiques culturelles caribéennes présentes",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "creolization",
              "slavery_memory",
              "resistance",
              "independence",
              "diaspora",
              "caribbean_nature",
              "traditional_knowledge",
              "oral_tradition",
              "caribbean_spirituality",
              "social_justice",
              "identity_language",
              "pan_caribbean",
              "colonialism_critique",
              "afrocaribbean",
              "indigineous_heritage",
              "carnival_culture",
              "caribbean_music_tradition",
              "maritime_culture"
            ]
          }
        },

        "cultural_expressions": {
          "type": "array",
          "description": "Expressions culturelles caribéennes spécifiques présentes",
          "items": {
            "type": "string",
            "enum": [
              "zouk", "gwo_ka", "biguine", "compas", "reggae", "soca",
              "calypso", "dancehall", "salsa", "merengue", "cumbia",
              "carnival", "jouvert", "mas",
              "bakoua", "madras", "wax",
              "creole_cuisine", "colombo", "acras",
              "laghia", "bele", "quadrille",
              "vodou", "shango", "obeah", "rastafari"
            ]
          }
        },

        "representation": {
          "type": "object",
          "description": "Indicateurs de représentation à l'écran / dans le contenu",
          "properties": {
            "afrodescendant_lead":   { "type": "boolean" },
            "indigenous_presence":   { "type": "boolean" },
            "creole_language_use":   { "type": "boolean" },
            "female_lead":           { "type": "boolean" },
            "youth_focus":           { "type": "boolean" },
            "diaspora_perspective":  { "type": "boolean" }
          }
        },

        "historical_period": {
          "type": "array",
          "description": "Période(s) historique(s) représentée(s)",
          "items": {
            "type": "string",
            "enum": [
              "pre_columbian",
              "colonial_early",
              "slavery_period",
              "abolition_era",
              "post_colonial",
              "contemporary",
              "futuristic"
            ]
          }
        }
      }
    },

    "rights": {
      "type": "object",
      "description": "Droits et licences",
      "properties": {

        "license": {
          "type": "string",
          "enum": [
            "all_rights_reserved",
            "cc_by",
            "cc_by_sa",
            "cc_by_nc",
            "cc_by_nc_sa",
            "cc_by_nd",
            "public_domain",
            "custom"
          ]
        },

        "rights_holder": { "type": "string" },

        "distribution_territories": {
          "type": "array",
          "description": "Territoires autorisés pour la diffusion",
          "items": { "type": "string" }
        },

        "embargo_until": {
          "type": "string",
          "format": "date"
        }
      }
    },

    "technical": {
      "type": "object",
      "description": "Métadonnées techniques",
      "properties": {
        "format":       { "type": "string", "examples": ["MP4", "MP3", "PDF", "EPUB", "TIFF"] },
        "resolution":   { "type": "string", "examples": ["4K", "1080p", "720p"] },
        "file_size_mb": { "type": "number" },
        "encoding":     { "type": "string" },
        "aspect_ratio": { "type": "string", "examples": ["16:9", "4:3", "2.39:1"] }
      }
    },

    "cms_compliance": {
      "type": "object",
      "description": "Certification de conformité CMS",
      "properties": {
        "certified":       { "type": "boolean" },
        "certified_date":  { "type": "string", "format": "date" },
        "certified_by":    { "type": "string", "default": "Caribwood Language Lab" },
        "compliance_level": {
          "type": "string",
          "enum": ["bronze", "silver", "gold", "platinum"],
          "description": "Niveau de conformité CMS selon le score d'ancrage caribéen et la complétude des métadonnées"
        },
        "validator_version": { "type": "string" }
      }
    }

  },

  "cms:compliance_levels": {
    "bronze":   { "min_score": 20, "required_fields": 6,  "description": "Ancrage caribéen minimal" },
    "silver":   { "min_score": 40, "required_fields": 10, "description": "Contenu caribéen identifié" },
    "gold":     { "min_score": 65, "required_fields": 14, "description": "Contenu caribéen affirmé" },
    "platinum": { "min_score": 85, "required_fields": 18, "description": "Standard caribéen de référence" }
  }
}
