<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Vérification CMS — Registre public officiel</title>
  <meta name="description" content="Vérifiez qu'une œuvre a été décrite selon le Caribbean Metadata Standard v2.0. Registre public officiel.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@400;500&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --dark:#0a0a0b;--navy:#003E6B;--navy2:#0f3d6b;--navy3:#0f6fa6;
  --teal:#00C2C7;--gold:#FFC93C;--coral:#FF6F61;--green:#3FA66B;
  --white:#fff;--off:#f4f2ee;--muted:#8899aa;--border:rgba(0,62,107,0.1);
  --surface:#fff;--bg:#f5f7fa;
}
html{scroll-behavior:smooth}
body{font-family:'DM Sans',system-ui,sans-serif;background:var(--bg);color:#1a1a1a;font-size:16px;line-height:1.6}

/* ── NAV placeholder (nav-fix.js) ── */
nav{min-height:68px}

/* ══════════════════════════════════════
   HERO — style premium index.html
══════════════════════════════════════ */
.hero{
  background:linear-gradient(135deg,#0b1e30 0%,var(--navy2) 50%,var(--navy3) 100%);
  padding:96px 6% 0;position:relative;overflow:hidden;
}
.hero-grid{
  position:absolute;inset:0;
  background-image:
    repeating-linear-gradient(0deg,transparent,transparent 47px,rgba(255,255,255,.025) 48px),
    repeating-linear-gradient(90deg,transparent,transparent 47px,rgba(255,255,255,.015) 48px);
}
.hero-glow{
  position:absolute;top:-80px;right:-60px;width:560px;height:560px;
  background:radial-gradient(ellipse,rgba(0,194,199,.18) 0%,transparent 65%);
  pointer-events:none;
}
.hero-glow-left{
  position:absolute;bottom:-120px;left:-80px;width:400px;height:400px;
  background:radial-gradient(ellipse,rgba(255,201,60,.07) 0%,transparent 65%);
  pointer-events:none;
}
.hero-inner{
  position:relative;z-index:1;max-width:760px;margin:0 auto;
  text-align:center;padding-bottom:56px;
}
.hero-eyebrow{
  font-family:'DM Mono',monospace;font-size:10px;letter-spacing:5px;
  color:var(--teal);margin-bottom:20px;display:inline-flex;align-items:center;
  gap:12px;text-transform:uppercase;
}
.hero-eyebrow::before,.hero-eyebrow::after{content:'';display:block;width:28px;height:1px;background:currentColor;opacity:.6}
.hero h1{
  font-family:'DM Serif Display',Georgia,serif;
  font-size:clamp(34px,5.5vw,58px);color:#fff;line-height:1.05;margin-bottom:18px;
}
.hero h1 em{color:var(--teal);font-style:italic}
.hero-desc{font-size:15px;color:rgba(255,255,255,.55);margin-bottom:44px;line-height:1.85;max-width:560px;margin-left:auto;margin-right:auto}

/* Search box — flottant sur le hero */
.search-float{
  background:#fff;border-radius:16px;padding:36px 40px;
  max-width:700px;margin:0 auto;position:relative;z-index:2;
  box-shadow:0 12px 60px rgba(0,0,0,.22),0 2px 8px rgba(0,0,0,.08);
  transform:translateY(32px);
}
.search-label{
  font-family:'DM Mono',monospace;font-size:10px;letter-spacing:2.5px;
  color:var(--muted);display:block;margin-bottom:12px;text-transform:uppercase;
}
.search-row{display:flex;gap:10px}
.search-input{
  flex:1;padding:16px 20px;
  border:2px solid var(--border);border-radius:8px;
  font-family:'DM Mono',monospace;font-size:14px;color:var(--navy);
  background:#fafbfc;transition:border .2s,box-shadow .2s;outline:none;letter-spacing:1.2px;
}
.search-input:focus{border-color:var(--teal);background:#fff;box-shadow:0 0 0 4px rgba(0,194,199,.1)}
.search-input::placeholder{color:#cdd;letter-spacing:1px}
.search-btn{
  padding:16px 32px;background:linear-gradient(135deg,var(--navy2),var(--navy3));
  color:#fff;border:none;border-radius:8px;font-family:'DM Sans',sans-serif;
  font-size:14px;font-weight:700;cursor:pointer;transition:opacity .2s,transform .2s;
  white-space:nowrap;letter-spacing:.3px;
}
.search-btn:hover{opacity:.9;transform:translateY(-1px)}
.search-hint{font-size:11px;color:#bcc;margin-top:12px;text-align:left;font-family:'DM Mono',monospace;letter-spacing:.5px}

/* ══════════════════════════════════════
   TRUST BAND
══════════════════════════════════════ */
.trust-band{
  background:var(--navy);padding:64px 6% 32px;margin-top:0;
}
.trust-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;max-width:900px;margin:0 auto}
.trust-item{padding:28px 24px;text-align:center}
.trust-num{
  font-family:'DM Serif Display',Georgia,serif;font-size:44px;
  color:var(--teal);line-height:1;margin-bottom:6px;
}
.trust-lbl{
  font-family:'DM Mono',monospace;font-size:10px;letter-spacing:2px;
  color:rgba(255,255,255,.45);text-transform:uppercase;
}
.trust-divider{width:1px;background:rgba(255,255,255,.07)}

/* ══════════════════════════════════════
   MAIN CONTENT
══════════════════════════════════════ */
main{max-width:820px;margin:0 auto;padding:52px 6% 88px}

/* States */
.state{display:none}
.state.active{display:block}

/* Loading */
.loading-wrap{text-align:center;padding:72px 20px}
.spinner-ring{
  width:48px;height:48px;margin:0 auto 20px;
  border:3px solid rgba(0,62,107,.1);border-top-color:var(--teal);
  border-radius:50%;animation:spin .75s linear infinite;
}
@keyframes spin{to{transform:rotate(360deg)}}
.loading-text{font-family:'DM Mono',monospace;font-size:11px;color:var(--muted);letter-spacing:3px}

/* Error */
.error-wrap{
  background:#fff;border-radius:14px;padding:52px;text-align:center;
  border:1px solid rgba(229,57,53,.12);box-shadow:0 2px 16px rgba(0,0,0,.05);
}
.error-icon{font-size:52px;margin-bottom:16px;line-height:1}
.error-title{font-family:'DM Serif Display',Georgia,serif;font-size:26px;color:#c0392b;margin-bottom:10px}
.error-sub{font-size:14px;color:var(--muted);line-height:1.8;max-width:400px;margin:0 auto}

/* ══════════════════════════════════════
   RESULT CARD
══════════════════════════════════════ */
.result-card{
  background:#fff;border-radius:16px;overflow:hidden;
  box-shadow:0 4px 32px rgba(0,62,107,.08);border:1px solid rgba(0,62,107,.06);
}

/* Header */
.result-header{
  padding:36px 40px;display:flex;align-items:flex-start;
  gap:24px;border-bottom:1px solid var(--border);
}
.cms-icon{
  width:76px;height:76px;border-radius:14px;
  background:rgba(0,194,199,.08);border:2px solid rgba(0,194,199,.2);
  display:flex;align-items:center;justify-content:center;font-size:30px;flex-shrink:0;
}
.result-work-title{
  font-family:'DM Serif Display',Georgia,serif;font-size:26px;
  color:var(--navy);margin-bottom:6px;line-height:1.2;
}
.result-creator{font-size:14px;color:var(--muted);margin-bottom:14px}
.result-tags{display:flex;flex-wrap:wrap;gap:8px}
.rtag{
  font-family:'DM Mono',monospace;font-size:10px;font-weight:500;
  padding:4px 14px;border-radius:20px;letter-spacing:1px;
}
.rtag.verified{background:#f0fdf4;color:#166534;border:1px solid rgba(63,166,107,.2)}
.rtag.info{background:#f0f7ff;color:var(--navy);border:1px solid rgba(0,62,107,.1)}

/* Completude */
.completude-section{padding:32px 40px;border-bottom:1px solid var(--border)}
.completude-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;flex-wrap:wrap;gap:12px}
.completude-title{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:3px;color:var(--teal);text-transform:uppercase}
.completude-pct{
  font-family:'DM Serif Display',Georgia,serif;font-size:46px;color:var(--navy);line-height:1;
}
.completude-sub{font-family:'DM Mono',monospace;font-size:10px;color:var(--muted);margin-top:4px;letter-spacing:.5px}

/* Progress bar */
.completude-bar-wrap{margin-bottom:24px}
.completude-bar-track{height:4px;background:rgba(0,62,107,.08);border-radius:2px;overflow:hidden}
.completude-bar-fill{height:100%;border-radius:2px;background:linear-gradient(90deg,var(--teal),var(--navy3));transition:width .6s ease}

.families-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
.fam-item{
  background:#f8fafc;border-radius:10px;padding:14px 16px;
  border:1px solid var(--border);transition:all .2s;
}
.fam-item.filled{background:#f0fdf4;border-color:rgba(63,166,107,.25)}
.fam-name{font-family:'DM Mono',monospace;font-size:9px;letter-spacing:1.5px;color:var(--muted);margin-bottom:5px;text-transform:uppercase}
.fam-item.filled .fam-name{color:#166534}
.fam-status{font-size:12px;font-weight:600;color:#cdd}
.fam-item.filled .fam-status{color:#166534}

/* Details */
.details-grid{display:grid;grid-template-columns:1fr 1fr;border-bottom:1px solid var(--border)}
.detail-item{padding:22px 40px;border-right:1px solid var(--border);border-bottom:1px solid var(--border)}
.detail-item:nth-child(2n){border-right:none}
.detail-label{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:2px;color:var(--muted);margin-bottom:6px;text-transform:uppercase}
.detail-value{font-size:14px;color:var(--navy);font-weight:600}

/* Tags */
.tags-section{padding:28px 40px;border-bottom:1px solid var(--border)}
.tags-family{margin-bottom:18px}
.tags-family-name{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:2px;color:var(--teal);margin-bottom:10px;text-transform:uppercase}
.tags-list{display:flex;flex-wrap:wrap;gap:6px}
.tag-pill{
  padding:5px 14px;background:#f0f7ff;border-radius:20px;
  font-size:12px;color:var(--navy);border:1px solid rgba(0,62,107,.08);
}

/* CMS ID */
.cms-id-section{
  padding:22px 40px;background:#fafbfc;
  display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;
}
.cms-id-label{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:2px;color:var(--muted);text-transform:uppercase}
.cms-id-value{font-family:'DM Mono',monospace;font-size:14px;color:var(--navy);font-weight:500;letter-spacing:1.5px}
.copy-id{
  font-family:'DM Mono',monospace;font-size:10px;padding:7px 16px;
  border:1px solid var(--border);border-radius:5px;background:#fff;
  cursor:pointer;color:var(--muted);transition:all .2s;letter-spacing:.5px;
}
.copy-id:hover{background:var(--navy);color:#fff;border-color:var(--navy)}

/* Valid Banner */
.valid-banner{
  background:#f0fdf4;padding:18px 40px;
  display:flex;align-items:center;gap:14px;
  border-left:4px solid var(--green);
}
.valid-banner.invalid{background:#fff5f5;border-left-color:#e53935}
.valid-icon{font-size:22px}
.valid-text{font-size:13px;color:#166534;font-weight:700}
.valid-text.invalid{color:#c0392b}
.valid-sub{font-size:12px;color:var(--muted);margin-top:2px}

/* ══════════════════════════════════════
   RECENT REGISTRY
══════════════════════════════════════ */
.registry-section{margin-top:56px}
.section-eyebrow{
  font-family:'DM Mono',monospace;font-size:10px;letter-spacing:4px;
  color:var(--teal);margin-bottom:24px;display:flex;align-items:center;gap:12px;
  text-transform:uppercase;
}
.section-eyebrow::before{content:'';display:block;width:24px;height:1px;background:var(--teal)}

.pub-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:40px}
.pstat{
  background:#fff;border-radius:12px;padding:24px;text-align:center;
  border:1px solid var(--border);box-shadow:0 2px 8px rgba(0,0,0,.03);
}
.pstat-num{font-family:'DM Serif Display',Georgia,serif;font-size:36px;color:var(--teal);line-height:1;margin-bottom:6px}
.pstat-lbl{font-family:'DM Mono',monospace;font-size:10px;color:var(--muted);letter-spacing:2px;text-transform:uppercase}

.recent-list{display:grid;gap:12px}
.recent-item{
  background:#fff;border-radius:10px;padding:18px 22px;
  border:1px solid var(--border);display:flex;align-items:center;gap:18px;
  transition:box-shadow .2s,transform .2s;cursor:pointer;
  box-shadow:0 2px 6px rgba(0,0,0,.03);
}
.recent-item:hover{box-shadow:0 6px 24px rgba(0,62,107,.1);transform:translateY(-1px)}
.ri-icon{
  width:40px;height:40px;border-radius:8px;
  background:rgba(0,194,199,.08);border:1px solid rgba(0,194,199,.2);
  display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;
}
.ri-info{flex:1}
.ri-title{font-size:14px;font-weight:600;color:var(--navy)}
.ri-meta{font-family:'DM Mono',monospace;font-size:10px;color:var(--muted);margin-top:3px;letter-spacing:.5px}
.ri-pct{font-family:'DM Serif Display',Georgia,serif;font-size:20px;color:var(--teal)}

/* ══════════════════════════════════════
   MEDIA QUERIES
══════════════════════════════════════ */
@media(max-width:700px){
  .search-row{flex-direction:column}
  .search-float{padding:28px 24px;border-radius:12px}
  .result-header{flex-direction:column;padding:24px}
  .details-grid{grid-template-columns:1fr}
  .detail-item{border-right:none;padding:16px 24px}
  .completude-section,.tags-section,.cms-id-section,.valid-banner{padding-left:24px;padding-right:24px}
  .pub-stats{grid-template-columns:1fr 1fr}
  .families-grid{grid-template-columns:1fr 1fr}
  .trust-grid{grid-template-columns:1fr}
  .trust-divider{display:none}
  .hero-eyebrow{font-size:9px}
}
</style>
</head>
<body>

<nav><!-- nav-fix.js --></nav>

<!-- ═══════════ HERO ═══════════ -->
<div class="hero">
  <div class="hero-grid"></div>
  <div class="hero-glow"></div>
  <div class="hero-glow-left"></div>
  <div class="hero-inner">
    <div class="hero-eyebrow">Registre Public Officiel</div>
    <h1>Vérifier une<br><em>certification CMS</em></h1>
    <p class="hero-desc">Entrez un identifiant CMS pour confirmer qu'une œuvre a été décrite selon le Caribbean Metadata Standard v2.0 et figure dans le registre officiel Caribwood.</p>

    <div class="search-float">
      <label class="search-label">Identifiant CMS</label>
      <div class="search-row">
        <input class="search-input" id="cms-input" type="text"
          placeholder="CMS-GUA-2026-XXXXXXXX"
          oninput="this.value=this.value.toUpperCase()"
          onkeydown="if(event.key==='Enter')verify()">
        <button class="search-btn" onclick="verify()">Vérifier →</button>
      </div>
      <div class="search-hint">Format : CMS-[TERRITOIRE]-[ANNÉE]-[8 CARACTÈRES]</div>
    </div>
  </div>
</div>

<!-- ═══════════ TRUST BAND ═══════════ -->
<div class="trust-band">
  <div class="trust-grid">
    <div class="trust-item">
      <div class="trust-num" id="stat-total">—</div>
      <div class="trust-lbl">Œuvres certifiées</div>
    </div>
    <div class="trust-divider"></div>
    <div class="trust-item">
      <div class="trust-num" id="stat-complete">—</div>
      <div class="trust-lbl">Fiches complètes</div>
    </div>
    <div class="trust-divider"></div>
    <div class="trust-item">
      <div class="trust-num" id="stat-territories">—</div>
      <div class="trust-lbl">Territoires représentés</div>
    </div>
  </div>
</div>

<!-- ═══════════ MAIN ═══════════ -->
<main>

  <!-- STATE : loading -->
  <div class="state" id="state-loading">
    <div class="loading-wrap">
      <div class="spinner-ring"></div>
      <div class="loading-text">Interrogation du registre CMS...</div>
    </div>
  </div>

  <!-- STATE : error -->
  <div class="state" id="state-error">
    <div class="error-wrap">
      <div class="error-icon">⊘</div>
      <div class="error-title" id="error-title">Identifiant invalide</div>
      <div class="error-sub" id="error-sub">Vérifiez le format et réessayez.</div>
    </div>
  </div>

  <!-- STATE : result -->
  <div class="state" id="state-result">
    <div class="result-card">

      <!-- Valid Banner -->
      <div class="valid-banner" id="valid-banner">
        <div class="valid-icon">✅</div>
        <div>
          <div class="valid-text" id="valid-text">Fiche authentique — Registre CMS officiel</div>
          <div class="valid-sub" id="valid-sub"></div>
        </div>
      </div>

      <!-- Header -->
      <div class="result-header">
        <div class="cms-icon">📋</div>
        <div style="flex:1">
          <div class="result-work-title" id="result-work-title">—</div>
          <div class="result-creator" id="result-creator">—</div>
          <div class="result-tags" id="result-tags"></div>
        </div>
      </div>

      <!-- Complétude -->
      <div class="completude-section">
        <div class="completude-header">
          <div class="completude-title">Indice de complétude CMS</div>
          <div>
            <div class="completude-pct" id="completude-pct">—</div>
            <div class="completude-sub" id="completude-sub">CMS v2.0</div>
          </div>
        </div>
        <div class="completude-bar-wrap">
          <div class="completude-bar-track">
            <div class="completude-bar-fill" id="completude-bar" style="width:0%"></div>
          </div>
        </div>
        <div class="families-grid" id="families-grid"></div>
      </div>

      <!-- Details -->
      <div class="details-grid" id="details-grid"></div>

      <!-- Tags sémantiques -->
      <div class="tags-section" id="tags-section" style="display:none"></div>

      <!-- CMS ID -->
      <div class="cms-id-section">
        <div>
          <div class="cms-id-label">Identifiant officiel</div>
          <div class="cms-id-value" id="cms-id-display">—</div>
        </div>
        <button class="copy-id" onclick="copyId()">⎘ Copier</button>
      </div>

    </div>
  </div>

  <!-- STATE : empty (default) -->
  <div class="state active" id="state-empty">
    <div class="registry-section">
      <div class="section-eyebrow">Dernières certifications</div>
      <div class="recent-list" id="recent-list">
        <div style="text-align:center;padding:40px;font-family:'DM Mono',monospace;font-size:11px;color:var(--muted)">Chargement du registre...</div>
      </div>
    </div>
  </div>

</main>

<footer><!-- nav-fix.js --></footer>

<script>
const SUPABASE_URL = 'https://vtbaqvjxfgseykjcinpu.supabase.co';
const SUPABASE_KEY = 'sb_publishable_cZc3a7kaK3M7ZcHRsoTI8w_NQz4Xy0z';

const FAMILIES = [
  {id:'identity',     label:'F01 · Identité'},
  {id:'linguistic',   label:'F02 · Linguistique'},
  {id:'cultural',     label:'F03 · Culturelle'},
  {id:'narrative',    label:'F04 · Narrative'},
  {id:'rhythmic',     label:'F05 · Rythmique'},
  {id:'geographic',   label:'F06 · Géographique'},
];

async function sbFetch(path, params='') {
  const r = await fetch(`${SUPABASE_URL}/rest/v1/${path}${params}`, {
    headers: {
      'apikey': SUPABASE_KEY,
      'Authorization': `Bearer ${SUPABASE_KEY}`,
      'Content-Type': 'application/json'
    }
  });
  if (!r.ok) throw new Error(`API error ${r.status}`);
  return r.json();
}

function showState(name) {
  document.querySelectorAll('.state').forEach(s => s.classList.remove('active'));
  document.getElementById('state-' + name).classList.add('active');
}

function calcCompletude(meta) {
  const tags = meta.metadata_tags || {};
  const filled = FAMILIES.filter(f => tags[f.id] && tags[f.id].length > 0).length;
  return { filled, pct: Math.round((filled / FAMILIES.length) * 100), tags };
}

async function verify() {
  const raw = document.getElementById('cms-input').value.trim().toUpperCase();
  if (!raw) return;

  if (!/^CMS-[A-Z]{2,5}-\d{4}-[A-Z0-9]{8}$/.test(raw)) {
    showState('error');
    document.getElementById('error-title').textContent = 'Format invalide';
    document.getElementById('error-sub').textContent = `"${raw}" n'est pas un identifiant CMS valide. Format attendu : CMS-GUA-2026-XXXXXXXX`;
    return;
  }

  showState('loading');

  try {
    const certs = await sbFetch('certifications',
      `?cms_id=eq.${encodeURIComponent(raw)}&select=*,works(title,title_original,family,year,territory,languages,creator_id,creators(name,type,territory))&limit=1`
    );

    if (!certs || certs.length === 0) {
      showState('error');
      document.getElementById('error-title').textContent = 'Fiche introuvable';
      document.getElementById('error-sub').textContent = `Aucune fiche "${raw}" dans le registre officiel CMS. Vérifiez l'identifiant ou contactez l'émetteur.`;
      return;
    }

    renderResult(certs[0]);
    showState('result');

  } catch(e) {
    showState('error');
    document.getElementById('error-title').textContent = 'Erreur de connexion';
    document.getElementById('error-sub').textContent = 'Impossible d\'interroger le registre CMS. Vérifiez votre connexion et réessayez.';
  }
}

function renderResult(cert) {
  const work = cert.works || {};
  const creator = work.creators || {};
  const meta = cert.metadata_json || {};
  const { filled, pct, tags } = calcCompletude(meta);

  // Valid banner
  const isRevoked = cert.revoked;
  const banner = document.getElementById('valid-banner');
  banner.className = 'valid-banner' + (isRevoked ? ' invalid' : '');
  const vt = document.getElementById('valid-text');
  vt.className = 'valid-text' + (isRevoked ? ' invalid' : '');
  vt.textContent = isRevoked ? '⚠️ Fiche révoquée — non valide' : '✅ Fiche authentique — Registre CMS officiel';
  document.getElementById('valid-sub').textContent = isRevoked
    ? `Révoquée le ${new Date(cert.revoked_at).toLocaleDateString('fr-FR')} — ${cert.revoked_reason || ''}`
    : `Enregistrée le ${new Date(cert.issued_at).toLocaleDateString('fr-FR')} · Caribwood Language Lab · caribbeanmetadata.org`;

  document.getElementById('result-work-title').textContent = work.title || '—';
  document.getElementById('result-creator').textContent = creator.name
    ? `Par ${creator.name}${creator.territory ? ' · ' + creator.territory : ''}`
    : '—';

  document.getElementById('result-tags').innerHTML = `
    ${work.family ? `<span class="rtag info">${work.family}</span>` : ''}
    ${work.territory ? `<span class="rtag info">📍 ${work.territory}</span>` : ''}
    ${work.year ? `<span class="rtag info">${work.year}</span>` : ''}
    <span class="rtag verified">✓ CMS v2.0</span>
  `;

  // Completude
  document.getElementById('completude-pct').textContent = pct + '%';
  document.getElementById('completude-bar').style.width = pct + '%';
  document.getElementById('completude-sub').textContent = `${filled} famille${filled > 1 ? 's' : ''} renseignée${filled > 1 ? 's' : ''} sur ${FAMILIES.length}`;
  document.getElementById('families-grid').innerHTML = FAMILIES.map(f => {
    const isFilled = tags[f.id] && tags[f.id].length > 0;
    return `<div class="fam-item ${isFilled ? 'filled' : ''}">
      <div class="fam-name">${f.label.toUpperCase()}</div>
      <div class="fam-status">${isFilled ? '✓ Renseignée' : '○ Vide'}</div>
    </div>`;
  }).join('');

  // Détails
  document.getElementById('details-grid').innerHTML = [
    {label:'Famille', value: work.family || '—'},
    {label:'Année', value: work.year || '—'},
    {label:'Territoire', value: work.territory || '—'},
    {label:'Langues', value: (work.languages||[]).join(', ') || '—'},
    {label:'Date d\'enregistrement', value: cert.issued_at ? new Date(cert.issued_at).toLocaleDateString('fr-FR',{day:'numeric',month:'long',year:'numeric'}) : '—'},
    {label:'Émis par', value: 'Caribwood Language Lab'},
  ].map(d => `<div class="detail-item"><div class="detail-label">${d.label}</div><div class="detail-value">${d.value}</div></div>`).join('');

  // Tags sémantiques
  const tagsSection = document.getElementById('tags-section');
  const familyNames = {
    linguistic:'Linguistique', cultural:'Culturelle', narrative:'Narrative',
    rhythmic:'Rythmique', geographic:'Géographique', sociohistorical:'Socio-historique'
  };
  const hasTags = Object.values(tags).some(t => t && t.length);
  if (hasTags) {
    tagsSection.style.display = '';
    tagsSection.innerHTML = Object.entries(tags).filter(([,t]) => t && t.length).map(([fam, t]) => `
      <div class="tags-family">
        <div class="tags-family-name">${(familyNames[fam]||fam).toUpperCase()}</div>
        <div class="tags-list">${t.map(x => `<span class="tag-pill">${x}</span>`).join('')}</div>
      </div>
    `).join('');
  } else {
    tagsSection.style.display = 'none';
  }

  document.getElementById('cms-id-display').textContent = cert.cms_id;
  window._currentCmsId = cert.cms_id;
}

function copyId() {
  if (window._currentCmsId) {
    navigator.clipboard.writeText(window._currentCmsId).then(() => {
      const btn = document.querySelector('.copy-id');
      btn.textContent = '✓ Copié';
      setTimeout(() => btn.textContent = '⎘ Copier', 2000);
    });
  }
}

async function loadStats() {
  try {
    const certs = await sbFetch('certifications', '?select=metadata_json,works(territory)&revoked=eq.false');
    if (!certs) return;
    document.getElementById('stat-total').textContent = certs.length;
    const complete = certs.filter(c => {
      const { pct } = calcCompletude(c.metadata_json || {});
      return pct === 100;
    }).length;
    document.getElementById('stat-complete').textContent = complete;
    const territories = new Set(certs.map(c => c.works?.territory).filter(Boolean));
    document.getElementById('stat-territories').textContent = territories.size;

    const recent = await sbFetch('certifications',
      '?select=cms_id,metadata_json,issued_at,works(title,territory,family)&revoked=eq.false&order=issued_at.desc&limit=6'
    );
    if (recent && recent.length) {
      document.getElementById('recent-list').innerHTML = recent.map(c => {
        const { pct } = calcCompletude(c.metadata_json || {});
        const fam = c.works?.family ? c.works.family.charAt(0).toUpperCase() + c.works.family.slice(1) : '';
        return `<div class="recent-item" onclick="loadCert('${c.cms_id}')">
          <div class="ri-icon">📋</div>
          <div class="ri-info">
            <div class="ri-title">${c.works?.title || '—'}</div>
            <div class="ri-meta">${c.cms_id} · ${c.works?.territory||''} ${fam ? '· ' + fam : ''}</div>
          </div>
          <div class="ri-pct">${pct}%</div>
        </div>`;
      }).join('');
    }
  } catch(e) { console.warn('Stats:', e); }
}

function loadCert(id) {
  document.getElementById('cms-input').value = id;
  verify();
}

const urlParams = new URLSearchParams(window.location.search);
const urlId = urlParams.get('id');
if (urlId) {
  document.getElementById('cms-input').value = urlId.toUpperCase();
  verify();
} else {
  loadStats();
}
</script>

<script src="nav-fix.js"></script>
</body>
