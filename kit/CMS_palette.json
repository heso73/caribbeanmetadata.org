      { "name": "Bleu Caraïbe profond", "hex": "#003E6B", "rgb": "0, 62, 107",   "role": "Institutionnel · Fond principal · Header", "keywords": ["sérieux", "institutionnel", "océan"] },
      { "name": "Turquoise digital",    "hex": "#00C2C7", "rgb": "0, 194, 199",  "role": "Accent principal · Liens · Icônes",          "keywords": ["innovation", "modernité", "tech"] },
      { "name": "Jaune soleil",         "hex": "#FFC93C", "rgb": "255, 201, 60", "role": "Accent secondaire · CTA · Mise en valeur",   "keywords": ["énergie", "culture", "chaleur"] }
    ],
    "secondary": [
      { "name": "Corail créole", "hex": "#FF6F61", "rgb": "255, 111, 97",  "role": "Alerte · Émotion · Famille Rythme",    "keywords": ["humanité", "émotion", "vivant"] },
      { "name": "Vert canne",    "hex": "#3FA66B", "rgb": "63, 166, 107",  "role": "Succès · Nature · Famille Géographie", "keywords": ["nature", "territoire", "croissance"] },
      { "name": "Gris graphite", "hex": "#2A2A2A", "rgb": "42, 42, 42",    "role": "Texte sombre · Fond alternatif",        "keywords": ["rigueur", "tech", "précision"] }
    ],
    "neutral": [
      { "name": "Blanc pur",  "hex": "#FFFFFF", "rgb": "255, 255, 255", "role": "Fond clair · Texte sur fond sombre" },
      { "name": "Gris clair", "hex": "#F2F2F2", "rgb": "242, 242, 242", "role": "Fond secondaire · Cartes sur fond clair" }
    ],
    "dark_theme": [
      { "name": "Fond principal",    "hex": "#0a0a0b", "rgb": "10, 10, 11",   "role": "Background principal dark theme" },
      { "name": "Fond carte",        "hex": "#111114", "rgb": "17, 17, 20",   "role": "Cards · Sections dark theme" },
      { "name": "Fond carte hover",  "hex": "#16161a", "rgb": "22, 22, 26",   "role": "Hover state dark theme" },
      { "name": "Texte principal",   "hex": "#e8e4d8", "rgb": "232, 228, 216","role": "Corps de texte dark theme" }
    ]
  },
  "usage": {
    "dark_theme":  { "background": "#0a0a0b", "card": "#111114", "text": "#e8e4d8", "accent": "#FFC93C", "link": "#00C2C7" },
    "light_theme": { "background": "#FFFFFF", "card": "#F2F2F2", "text": "#2A2A2A", "accent": "#003E6B", "link": "#00C2C7" }
